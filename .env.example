# LLM runtime
NEUROHEALTH_LLM_PROVIDER=ollama
NEUROHEALTH_LLM_MODEL=llama3.2:3b
NEUROHEALTH_LLM_ENABLED=1
OLLAMA_BASE_URL=http://127.0.0.1:11434

# Live nearby-provider search
NEUROHEALTH_LIVE_MAPS_ENABLED=1
NEUROHEALTH_MAPS_PROVIDER=osm
NEUROHEALTH_NOMINATIM_URL=https://nominatim.openstreetmap.org/search
NEUROHEALTH_OVERPASS_URL=https://overpass-api.de/api/interpreter
NEUROHEALTH_MAPS_TIMEOUT_SECONDS=12
NEUROHEALTH_MAPS_USER_AGENT=NeuroHealth/0.1 (clinical-assistant prototype)
